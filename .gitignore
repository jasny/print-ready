# Ignore all pipeline data files, keep directory markers
00-input/*
01-validate/*
02-analyze-dpi/*
03-split-pages/*
04-rasterize-lowdpi/*
05-upscale/*
06-rebuild-pages/*
07-merge-pages/*
08-normalize-pdf/*
09-preflight/*
10-output/*

!.gitignore
!*/
!00-input/.gitkeep
!01-validate/.gitkeep
!02-analyze-dpi/.gitkeep
!03-split-pages/.gitkeep
!04-rasterize-lowdpi/.gitkeep
!05-upscale/.gitkeep
!06-rebuild-pages/.gitkeep
!07-merge-pages/.gitkeep
!08-normalize-pdf/.gitkeep
!09-preflight/.gitkeep
!10-output/.gitkeep
